@Book{stender,
author="Stender, Daniel",
title="Cloud-Infrastrukturen: das Handbuch f{\"u}r DevOps-Teams und Administratoren",
series="Rheinwerk computing",
year="2020",
edition="1. Auflage",
publisher="Rheinwerk Computing",
