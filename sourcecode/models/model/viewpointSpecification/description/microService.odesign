        <toolSections name="Verbindungen">
          <ownedTools xsi:type="tool:EdgeCreationDescription" name="Controller-Service Dependency" label="Controller-Service Dependency" edgeMappings="//@ownedViewpoints[name='ModelViewpoint']/@ownedRepresentations[name='DomainModelDescription']/@defaultLayer/@edgeMappings[name='serviceMaintainedBy']">
