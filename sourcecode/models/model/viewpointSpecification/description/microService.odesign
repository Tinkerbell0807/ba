<?xml version="1.0" encoding="UTF-8"?>
<description:Group xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:description="http://www.eclipse.org/sirius/description/1.1.0" xmlns:description_1="http://www.eclipse.org/sirius/diagram/description/1.1.0" xmlns:properties="http://www.eclipse.org/sirius/properties/1.0.0" xmlns:style="http://www.eclipse.org/sirius/diagram/description/style/1.1.0" xmlns:tool="http://www.eclipse.org/sirius/diagram/description/tool/1.1.0" xmlns:tool_1="http://www.eclipse.org/sirius/description/tool/1.1.0" name="microService" version="12.0.0.2017041100">
  <ownedViewpoints name="MyViewpoint" modelFileExtension="*.microservicemetamodell">
    <ownedRepresentations xsi:type="description_1:DiagramDescription" name="SystemModelDescription" domainClass="microserviceMetamodell::SystemModel" enablePopupBars="true">
      <metamodel href="http://microservice.com/microserviceMetamodell#/"/>
      <defaultLayer name="domainModelLayer">
        <nodeMappings name="systemModel" semanticCandidatesExpression="aql:self" domainClass="microserviceMetamodell::SystemModel">
          <style xsi:type="style:NoteDescription" labelSize="14" labelExpression="feature:description" labelPosition="node" resizeKind="NSEW">
            <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
            <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
            <color xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='light_yellow']"/>
          </style>
        </nodeMappings>
        <edgeMappings name="serviceMaintainedBy" label="serviceMaintainedBy" sourceMapping="//@ownedViewpoints[name='MyViewpoint']/@ownedRepresentations[name='SystemModelDescription']/@defaultLayer/@containerMappings[name='domainWebserviceContainer']/@subContainerMappings[name='domainObjectContainer']/@subNodeMappings[name='domainObjectControllerNode']" targetMapping="//@ownedViewpoints[name='MyViewpoint']/@ownedRepresentations[name='SystemModelDescription']/@defaultLayer/@containerMappings[name='domainWebserviceContainer']/@subContainerMappings[name='domainObjectContainer']/@subNodeMappings[name='domainServiceNode']" targetFinderExpression="aql:self.domainObjectServices">
          <style targetArrow="InputFillClosedArrow" sizeComputationExpression="2">
            <strokeColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='light_orange']"/>
            <centerLabelStyleDescription labelSize="12">
              <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
            </centerLabelStyleDescription>
          </style>
        </edgeMappings>
        <edgeMappings name="repositoryMaintainedBy" label="repositoryMaintainedBy" sourceMapping="//@ownedViewpoints[name='MyViewpoint']/@ownedRepresentations[name='SystemModelDescription']/@defaultLayer/@containerMappings[name='domainWebserviceContainer']/@subContainerMappings[name='domainObjectContainer']/@subNodeMappings[name='domainServiceNode']" targetMapping="//@ownedViewpoints[name='MyViewpoint']/@ownedRepresentations[name='SystemModelDescription']/@defaultLayer/@containerMappings[name='domainWebserviceContainer']/@subContainerMappings[name='domainObjectContainer']/@subNodeMappings[name='domainRepositoryNode']" targetFinderExpression="aql:self.domainObjectRepositories">
          <style targetArrow="InputFillClosedArrow" sizeComputationExpression="2">
            <strokeColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='dark_orange']"/>
            <centerLabelStyleDescription labelSize="12">
              <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
            </centerLabelStyleDescription>
          </style>
        </edgeMappings>
        <edgeMappings name="calls" sourceMapping="//@ownedViewpoints[name='MyViewpoint']/@ownedRepresentations[name='SystemModelDescription']/@defaultLayer/@containerMappings[name='domainWebserviceContainer']/@subContainerMappings[name='domainObjectContainer']/@subNodeMappings[name='domainServiceNode']" targetMapping="//@ownedViewpoints[name='MyViewpoint']/@ownedRepresentations[name='SystemModelDescription']/@defaultLayer/@containerMappings[name='domainWebserviceContainer']/@subContainerMappings[name='domainObjectContainer']/@subNodeMappings[name='domainObjectControllerNode']/@borderedNodeMappings[name='restEndpointNode']" targetFinderExpression="aql:self.calls">
          <style targetArrow="InputFillClosedArrow" sizeComputationExpression="2" routingStyle="manhattan">
            <strokeColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
            <centerLabelStyleDescription labelSize="12">
              <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
            </centerLabelStyleDescription>
          </style>
        </edgeMappings>
        <containerMappings name="domainWebserviceContainer" label="domainWebservice" domainClass="microserviceMetamodell::DomainWebservice">
          <borderedNodeMappings name="hostUrl" label="hostUrl" semanticCandidatesExpression="aql:self" domainClass="microserviceMetamodell::DomainWebservice">
            <style xsi:type="style:SquareDescription" labelSize="12" labelExpression="feature:hostUrl" labelPosition="node" resizeKind="NSEW" width="20" height="4">
              <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
              <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
              <color xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='light_green']"/>
            </style>
          </borderedNodeMappings>
          <subContainerMappings name="domainObjectContainer" label="domainObject" semanticCandidatesExpression="aql:self.domainObjects" domainClass="microserviceMetamodell::DomainObject">
            <subNodeMappings name="domainObjectControllerNode" label="domainObjectController" semanticCandidatesExpression="aql:self.domainObjectController" domainClass="DomainObjectController">
              <borderedNodeMappings name="restEndpointNode" label="restEndpoints" semanticCandidatesExpression="aql:self.restEndpoints" domainClass="microserviceMetamodell::RestEndpoint">
                <conditionnalStyles predicateExpression="aql:self.httpMethod==microserviceMetamodell::HttpMethod::GET">
                  <style xsi:type="style:SquareDescription" labelSize="12" labelExpression="feature:path" labelPosition="node" resizeKind="NSEW">
                    <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
                    <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
                    <color xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='light_green']"/>
                  </style>
                </conditionnalStyles>
                <conditionnalStyles predicateExpression="aql:self.httpMethod==microserviceMetamodell::HttpMethod::POST">
                  <style xsi:type="style:SquareDescription" labelSize="12" labelExpression="feature:path" labelPosition="node" resizeKind="NSEW">
                    <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
                    <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
                    <color xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='light_blue']"/>
                  </style>
                </conditionnalStyles>
                <conditionnalStyles predicateExpression="aql:self.httpMethod==microserviceMetamodell::HttpMethod::DELETE">
                  <style xsi:type="style:SquareDescription" labelSize="12" labelExpression="feature:path" labelPosition="node" resizeKind="NSEW">
                    <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
                    <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
                    <color xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='light_red']"/>
                  </style>
                </conditionnalStyles>
              </borderedNodeMappings>
              <style xsi:type="style:SquareDescription" labelSize="12" labelExpression="feature:objectName" labelPosition="node" resizeKind="NSEW" width="20" height="6">
                <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
                <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
                <color xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='light_orange']"/>
              </style>
            </subNodeMappings>
            <subNodeMappings name="domainServiceNode" label="domainService" semanticCandidatesExpression="aql:self.domainObjectService" domainClass="microserviceMetamodell::DomainObjectService">
              <style xsi:type="style:SquareDescription" labelSize="12" labelExpression="feature:objectName" labelPosition="node" resizeKind="NSEW" width="20" height="6">
                <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
                <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
                <color xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='light_yellow']"/>
              </style>
            </subNodeMappings>
            <subNodeMappings name="domainRepositoryNode" label="domainRepository" semanticCandidatesExpression="aql:self.domainObjectRepository" domainClass="microserviceMetamodell::DomainObjectRepository">
              <style xsi:type="style:SquareDescription" labelSize="12" labelExpression="feature:objectName" labelPosition="node" resizeKind="NSEW" width="20" height="6">
                <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
                <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
                <color xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='light_chocolate']"/>
              </style>
            </subNodeMappings>
            <style xsi:type="style:FlatContainerStyleDescription" borderSizeComputationExpression="1" labelSize="12" labelExpression="feature:objectName">
              <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
              <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
              <backgroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='light_purple']"/>
              <foregroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='purple']"/>
            </style>
          </subContainerMappings>
          <style xsi:type="style:FlatContainerStyleDescription" borderSizeComputationExpression="1" labelSize="12" labelExpression="feature:domainName">
            <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
            <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
            <backgroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='white']"/>
            <foregroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='light_gray']"/>
          </style>
        </containerMappings>
        <toolSections name="Objekte">
          <ownedTools xsi:type="tool:ContainerCreationDescription" name="WebserviceCreation" label="Webservice" containerMappings="//@ownedViewpoints[name='MyViewpoint']/@ownedRepresentations[name='SystemModelDescription']/@defaultLayer/@containerMappings[name='domainWebserviceContainer']">
            <variable name="container"/>
            <viewVariable name="containerView"/>
            <initialOperation>
              <firstModelOperations xsi:type="tool_1:ChangeContext" browseExpression="var:container">
                <subModelOperations xsi:type="tool_1:CreateInstance" typeName="microserviceMetamodell::DomainWebservice" referenceName="webservices">
                  <subModelOperations xsi:type="tool_1:SetValue" featureName="domainName" valueExpression="DefaultDomain"/>
                  <subModelOperations xsi:type="tool_1:SetValue" featureName="hostUrl" valueExpression="DefaultHostUrl"/>
                </subModelOperations>
              </firstModelOperations>
            </initialOperation>
          </ownedTools>
          <ownedTools xsi:type="tool:ContainerCreationDescription" name="DomainObject" label="DomainObject" containerMappings="//@ownedViewpoints[name='MyViewpoint']/@ownedRepresentations[name='SystemModelDescription']/@defaultLayer/@containerMappings[name='domainWebserviceContainer']/@subContainerMappings[name='domainObjectContainer']">
            <variable name="container"/>
            <viewVariable name="containerView"/>
            <initialOperation>
              <firstModelOperations xsi:type="tool_1:ChangeContext" browseExpression="var:container">
                <subModelOperations xsi:type="tool_1:CreateInstance" typeName="microserviceMetamodell::DomainObject" referenceName="domainObjects">
                  <subModelOperations xsi:type="tool_1:SetValue" featureName="objectName" valueExpression="DefaultDomainName"/>
                </subModelOperations>
              </firstModelOperations>
            </initialOperation>
          </ownedTools>
          <ownedTools xsi:type="tool:NodeCreationDescription" name="Controller" label="Controller" precondition="aql:self.oclIsTypeOf(microserviceMetamodell::DomainObject)" nodeMappings="//@ownedViewpoints[name='MyViewpoint']/@ownedRepresentations[name='SystemModelDescription']/@defaultLayer/@containerMappings[name='domainWebserviceContainer']/@subContainerMappings[name='domainObjectContainer']/@subNodeMappings[name='domainObjectControllerNode']" extraMappings="//@ownedViewpoints[name='MyViewpoint']/@ownedRepresentations[name='SystemModelDescription']/@defaultLayer/@containerMappings[name='domainWebserviceContainer']/@subContainerMappings[name='domainObjectContainer']">
            <variable name="container"/>
            <viewVariable name="containerView"/>
            <initialOperation>
              <firstModelOperations xsi:type="tool_1:ChangeContext" browseExpression="aql:self.eContainer().oclAsType(microserviceMetamodell::DomainWebservice)">
                <subModelOperations xsi:type="tool_1:CreateInstance" typeName="microserviceMetamodell::DomainObjectController" referenceName="domainObjectControllers">
                  <subModelOperations xsi:type="tool_1:ChangeContext" browseExpression="var:container">
                    <subModelOperations xsi:type="tool_1:SetValue" featureName="domainObjectController" valueExpression="var:instance"/>
                  </subModelOperations>
                  <subModelOperations xsi:type="tool_1:SetValue" featureName="objectName" valueExpression="DefaultDomainController"/>
                </subModelOperations>
              </firstModelOperations>
            </initialOperation>
          </ownedTools>
          <ownedTools xsi:type="tool:NodeCreationDescription" name="RestEndpoint" label="RestEndpoint" precondition="aql:self.oclIsTypeOf(microserviceMetamodell::DomainObjectController)" nodeMappings="//@ownedViewpoints[name='MyViewpoint']/@ownedRepresentations[name='SystemModelDescription']/@defaultLayer/@containerMappings[name='domainWebserviceContainer']/@subContainerMappings[name='domainObjectContainer']/@subNodeMappings[name='domainObjectControllerNode']/@borderedNodeMappings[name='restEndpointNode']">
            <variable name="container"/>
            <viewVariable name="containerView"/>
            <initialOperation>
              <firstModelOperations xsi:type="tool_1:ChangeContext" browseExpression="var:container">
                <subModelOperations xsi:type="tool_1:CreateInstance" typeName="microserviceMetamodell::RestEndpoint" referenceName="restEndpoints">
                  <subModelOperations xsi:type="tool_1:SetValue" featureName="path" valueExpression="/defaultApiRoute"/>
                </subModelOperations>
              </firstModelOperations>
            </initialOperation>
          </ownedTools>
          <ownedTools xsi:type="tool:NodeCreationDescription" name="Service" label="Service" precondition="aql:self.oclIsTypeOf(microserviceMetamodell::DomainObject)" nodeMappings="//@ownedViewpoints[name='MyViewpoint']/@ownedRepresentations[name='SystemModelDescription']/@defaultLayer/@containerMappings[name='domainWebserviceContainer']/@subContainerMappings[name='domainObjectContainer']/@subNodeMappings[name='domainServiceNode']">
            <variable name="container"/>
            <viewVariable name="containerView"/>
            <initialOperation>
              <firstModelOperations xsi:type="tool_1:ChangeContext" browseExpression="aql:self.eContainer().oclAsType(microserviceMetamodell::DomainWebservice)">
                <subModelOperations xsi:type="tool_1:CreateInstance" typeName="microserviceMetamodell::DomainObjectService" referenceName="domainObjectServices">
                  <subModelOperations xsi:type="tool_1:ChangeContext" browseExpression="var:container">
                    <subModelOperations xsi:type="tool_1:SetValue" featureName="domainObjectService" valueExpression="var:instance"/>
                  </subModelOperations>
                  <subModelOperations xsi:type="tool_1:SetValue" featureName="objectName" valueExpression="DefaultDomainService"/>
                </subModelOperations>
              </firstModelOperations>
            </initialOperation>
          </ownedTools>
          <ownedTools xsi:type="tool:NodeCreationDescription" name="Repository" label="Repository" nodeMappings="//@ownedViewpoints[name='MyViewpoint']/@ownedRepresentations[name='SystemModelDescription']/@defaultLayer/@containerMappings[name='domainWebserviceContainer']/@subContainerMappings[name='domainObjectContainer']/@subNodeMappings[name='domainRepositoryNode']">
            <variable name="container"/>
            <viewVariable name="containerView"/>
            <initialOperation>
              <firstModelOperations xsi:type="tool_1:ChangeContext" browseExpression="aql:self.eContainer().oclAsType(microserviceMetamodell::DomainWebservice)">
                <subModelOperations xsi:type="tool_1:CreateInstance" typeName="microserviceMetamodell::DomainObjectRepository" referenceName="domainObjectRepositories">
                  <subModelOperations xsi:type="tool_1:ChangeContext" browseExpression="var:container">
                    <subModelOperations xsi:type="tool_1:SetValue" featureName="domainObjectRepository" valueExpression="var:instance"/>
                  </subModelOperations>
                  <subModelOperations xsi:type="tool_1:SetValue" featureName="objectName" valueExpression="DefaultDomainRepository"/>
                </subModelOperations>
              </firstModelOperations>
            </initialOperation>
          </ownedTools>
        </toolSections>
        <toolSections name="Verbindungen">
          <ownedTools xsi:type="tool:EdgeCreationDescription" name="Controller-Service Dependency" label="Controller-Service Dependency" edgeMappings="//@ownedViewpoints[name='MyViewpoint']/@ownedRepresentations[name='SystemModelDescription']/@defaultLayer/@edgeMappings[name='serviceMaintainedBy']">
            <sourceVariable name="source"/>
            <targetVariable name="target"/>
            <sourceViewVariable name="sourceView"/>
            <targetViewVariable name="targetView"/>
            <initialOperation>
              <firstModelOperations xsi:type="tool_1:ChangeContext" browseExpression="var:source">
                <subModelOperations xsi:type="tool_1:SetValue" featureName="domainObjectServices" valueExpression="var:target"/>
              </firstModelOperations>
            </initialOperation>
          </ownedTools>
          <ownedTools xsi:type="tool:EdgeCreationDescription" name="Service-Repository Dependency" label="Service-Repository Dependency" edgeMappings="//@ownedViewpoints[name='MyViewpoint']/@ownedRepresentations[name='SystemModelDescription']/@defaultLayer/@edgeMappings[name='repositoryMaintainedBy']">
            <sourceVariable name="source"/>
            <targetVariable name="target"/>
            <sourceViewVariable name="sourceView"/>
            <targetViewVariable name="targetView"/>
            <initialOperation>
              <firstModelOperations xsi:type="tool_1:ChangeContext" browseExpression="var:source">
                <subModelOperations xsi:type="tool_1:SetValue" featureName="domainObjectRepositories" valueExpression="var:target"/>
              </firstModelOperations>
            </initialOperation>
          </ownedTools>
          <ownedTools xsi:type="tool:EdgeCreationDescription" name="REST Call" edgeMappings="//@ownedViewpoints[name='MyViewpoint']/@ownedRepresentations[name='SystemModelDescription']/@defaultLayer/@edgeMappings[name='calls']">
            <sourceVariable name="source"/>
            <targetVariable name="target"/>
            <sourceViewVariable name="sourceView"/>
            <targetViewVariable name="targetView"/>
            <initialOperation>
              <firstModelOperations xsi:type="tool_1:ChangeContext" browseExpression="var:source">
                <subModelOperations xsi:type="tool_1:SetValue" featureName="calls" valueExpression="var:target"/>
              </firstModelOperations>
            </initialOperation>
          </ownedTools>
        </toolSections>
      </defaultLayer>
    </ownedRepresentations>
  </ownedViewpoints>
  <extensions xsi:type="properties:ViewExtensionDescription" name="CustomProperties">
    <categories name="Default Category">
      <pages name="REST Config Page" label="REST Config Page" labelExpression="REST Config" domainClass="microserviceMetamodell::RestEndpoint" semanticCandidateExpression="var:self" groups="//@extensions.0/@categories.0/@groups.0"/>
      <groups name="REST Config Group" label="REST Config Group" labelExpression="Group" domainClass="microserviceMetamodell::RestEndpoint" semanticCandidateExpression="var:self">
        <controls xsi:type="properties:RadioDescription" name="HTTP Method Radio Button" label="HTTP Method Radio Button" labelExpression="HTTP Method" valueExpression="feature:httpMethod" candidatesExpression="aql:Sequence{microserviceMetamodell::HttpMethod::GET, microserviceMetamodell::HttpMethod::POST, microserviceMetamodell::HttpMethod::DELETE}" candidateDisplayExpression="aql:candidate.toString()" numberOfColumns="1">
          <initialOperation>
            <firstModelOperations xsi:type="tool_1:SetValue" featureName="httpMethod" valueExpression="var:newValue"/>
          </initialOperation>
        </controls>
        <controls xsi:type="properties:TextDescription" name="URI" label="URI Textfield" labelExpression="URI:" valueExpression="aql:self.path">
          <initialOperation>
            <firstModelOperations xsi:type="tool_1:SetValue" featureName="path" valueExpression="var:newValue"/>
          </initialOperation>
        </controls>
      </groups>
    </categories>
  </extensions>
</description:Group>
