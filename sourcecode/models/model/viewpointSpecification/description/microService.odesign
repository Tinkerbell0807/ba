                    <backgroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='light_green']"/>
                    <foregroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='light_green']"/>
                  </style>
                </subContainerMappings>
                <subContainerMappings name="behaviour" semanticCandidatesExpression="aql:self.behaviours" domainClass="microserviceMetamodell::Behaviour">
                  <style xsi:type="style:FlatContainerStyleDescription" borderSizeComputationExpression="1" labelSize="14" labelExpression="aql:self.behaviourName" iconPath="/microService.design/ressources/icons/Behaviour32px.png">
                    <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
                    <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
                    <backgroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='white']"/>
                    <foregroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='white']"/>
                  </style>
                </subContainerMappings>
                <style xsi:type="style:FlatContainerStyleDescription" borderSizeComputationExpression="1" labelSize="14" labelExpression="aql:self.elementName" iconPath="/microService.design/ressources/icons/EntityIcon32px.png">
                  <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
                  <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
                  <backgroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='green']"/>
                  <foregroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='green']"/>
                </style>
              </subContainerMappings>
              <style xsi:type="style:FlatContainerStyleDescription" borderSizeComputationExpression="1" labelSize="14" labelExpression="aql:self.elementName" iconPath="/microService.design/ressources/icons/AggregateIcon32px.png">
                <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
                <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
                <backgroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='yellow']"/>
                <foregroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='yellow']"/>
              </style>
            </subContainerMappings>
            <subContainerMappings name="valueObject" semanticCandidatesExpression="aql:self.modelElements" domainClass="microserviceMetamodell::ValueObject" childrenPresentation="VerticalStack">
              <subContainerMappings name="valueObject" semanticCandidatesExpression="aql:self.valueObjects" domainClass="microserviceMetamodell::ValueObject" reusedContainerMappings="//@ownedViewpoints[name='ModelViewpoint']/@ownedRepresentations[name='MicroserviceImplementationDescription']/@defaultLayer/@containerMappings[name='boundedContext']/@subContainerMappings[name='sharedModule']/@subContainerMappings[name='valueObject']/@subContainerMappings[name='valueObject']" childrenPresentation="VerticalStack">
                <style xsi:type="style:FlatContainerStyleDescription" borderSizeComputationExpression="1" labelSize="12" labelExpression="aql:self.elementName" iconPath="/microService.design/ressources/icons/ValueIcon32px.png">
                  <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
                  <labelFormat>italic</labelFormat>
                  <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
                  <backgroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='light_purple']"/>
                  <foregroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='light_purple']"/>
                </style>
              </subContainerMappings>
              <style xsi:type="style:FlatContainerStyleDescription" borderSizeComputationExpression="1" labelSize="14" labelExpression="aql:self.elementName" iconPath="/microService.design/ressources/icons/ValueIcon32px.png">
                <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
                <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
                <backgroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='light_purple']"/>
                <foregroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='light_purple']"/>
              </style>
            </subContainerMappings>
            <subContainerMappings name="submodule" semanticCandidatesExpression="aql:self.submodules" domainClass="microserviceMetamodell::Module" reusedContainerMappings="//@ownedViewpoints[name='ModelViewpoint']/@ownedRepresentations[name='MicroserviceImplementationDescription']/@defaultLayer/@containerMappings[name='boundedContext']/@subContainerMappings[name='sharedModule']/@subContainerMappings[name='submodule']">
              <style xsi:type="style:FlatContainerStyleDescription" borderSizeComputationExpression="1" labelSize="14" labelExpression="aql:self.moduleName" labelAlignment="LEFT">
                <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
                <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
                <backgroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='white']"/>
                <foregroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='white']"/>
              </style>
            </subContainerMappings>
            <style xsi:type="style:FlatContainerStyleDescription" borderSizeComputationExpression="1" labelSize="14" labelExpression="aql:self.moduleName" labelAlignment="LEFT">
              <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
              <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
              <backgroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='white']"/>
              <foregroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='white']"/>
            </style>
          </subContainerMappings>
          <style xsi:type="style:FlatContainerStyleDescription" borderSizeComputationExpression="1" labelSize="14" labelExpression="aql:self.contextName">
            <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
            <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
            <backgroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='light_orange']"/>
            <foregroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='light_orange']"/>
          </style>
        </containerMappings>
      </defaultLayer>
    </ownedRepresentations>
    <ownedRepresentations xsi:type="description_1:DiagramDescription" name="MicroserviceCommunicationDescription" domainClass="microserviceMetamodell::SystemModel" enablePopupBars="true">
      <defaultLayer name="technicalLayerElements">
        <edgeMappings name="sendsRequestTo" sourceMapping="//@ownedViewpoints[name='ModelViewpoint']/@ownedRepresentations[name='MicroserviceCommunicationDescription']/@defaultLayer/@containerMappings[name='microservice']" targetMapping="//@ownedViewpoints[name='ModelViewpoint']/@ownedRepresentations[name='MicroserviceCommunicationDescription']/@defaultLayer/@containerMappings[name='microservice']/@borderedNodeMappings[name='synchronousInterface']/@borderedNodeMappings[name='endpoints']" targetFinderExpression="aql:self.sendsRequestTo">
          <style targetArrow="InputFillClosedArrow" sizeComputationExpression="2" routingStyle="manhattan">
            <strokeColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
            <centerLabelStyleDescription labelSize="12">
              <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
            </centerLabelStyleDescription>
          </style>
        </edgeMappings>
        <edgeMappings name="usesKafkaTopic" sourceMapping="//@ownedViewpoints[name='ModelViewpoint']/@ownedRepresentations[name='MicroserviceCommunicationDescription']/@defaultLayer/@containerMappings[name='microservice']/@borderedNodeMappings[name='asynchronousInterface']" targetMapping="//@ownedViewpoints[name='ModelViewpoint']/@ownedRepresentations[name='MicroserviceCommunicationDescription']/@defaultLayer/@containerMappings[name='topic']" targetFinderExpression="aql:self.topic">
          <conditionnalStyles predicateExpression="aql:self.interfaceRole==microserviceMetamodell::AsynchronousInterfaceRole::PRODUCER">
            <style targetArrow="InputFillClosedArrow" sizeComputationExpression="2">
              <strokeColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='light_red']"/>
              <centerLabelStyleDescription labelSize="12">
                <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
              </centerLabelStyleDescription>
            </style>
          </conditionnalStyles>
          <conditionnalStyles predicateExpression="aql:self.interfaceRole==microserviceMetamodell::AsynchronousInterfaceRole::CONSUMER">
            <style sourceArrow="InputFillClosedArrow" targetArrow="NoDecoration" sizeComputationExpression="2">
              <strokeColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='light_red']"/>
              <centerLabelStyleDescription labelSize="12">
                <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
              </centerLabelStyleDescription>
            </style>
          </conditionnalStyles>
        </edgeMappings>
        <containerMappings name="microservice" semanticCandidatesExpression="aql:self.technicalLayer.microservices" domainClass="microserviceMetamodell::Microservice">
          <borderedNodeMappings name="synchronousInterface" semanticCandidatesExpression="aql:self.interfaces" domainClass="microserviceMetamodell::SynchronousInterface">
            <borderedNodeMappings name="endpoints" semanticCandidatesExpression="aql:self.restEndpoints" domainClass="microserviceMetamodell::RestEndpoint">
              <style xsi:type="style:SquareDescription" labelSize="12" labelExpression="aql:self.path" labelPosition="node" resizeKind="NSEW">
                <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
                <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
                <color xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='light_blue']"/>
              </style>
            </borderedNodeMappings>
            <style xsi:type="style:DotDescription" labelSize="12" labelExpression="aql:self.interfaceName" labelPosition="node" resizeKind="NSEW">
              <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
              <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
              <backgroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='light_purple']"/>
            </style>
          </borderedNodeMappings>
          <borderedNodeMappings name="asynchronousInterface" semanticCandidatesExpression="aql:self.interfaces" domainClass="microserviceMetamodell::AsynchronousInterface">
            <style xsi:type="style:DotDescription" labelSize="12" labelExpression="aql:self.interfaceName" labelPosition="node" resizeKind="NSEW">
              <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
              <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
              <backgroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='light_red']"/>
            </style>
          </borderedNodeMappings>
          <style xsi:type="style:FlatContainerStyleDescription" borderSizeComputationExpression="1" labelSize="14" labelExpression="aql:self.serviceName">
            <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
            <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
            <backgroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='light_gray']"/>
            <foregroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='light_gray']"/>
          </style>
        </containerMappings>
        <containerMappings name="topic" semanticCandidatesExpression="aql:self.infrastructureLayer.eventingConfigurations.topics" domainClass="Topic">
          <style xsi:type="style:FlatContainerStyleDescription" borderSizeComputationExpression="1" labelSize="12" labelExpression="aql:self.topicNameAbbreviation">
            <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
            <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
            <backgroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='light_yellow']"/>
            <foregroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='light_yellow']"/>
          </style>
        </containerMappings>
      </defaultLayer>
    </ownedRepresentations>
    <ownedRepresentations xsi:type="description_1:DiagramDescription" name="InfrastructureDescription" enablePopupBars="true">
      <defaultLayer name="Default"/>
    </ownedRepresentations>
  </ownedViewpoints>
  <extensions xsi:type="properties:ViewExtensionDescription" name="CustomProperties">
    <categories name="Default Category">
      <pages name="REST Config Page" label="REST Config Page" labelExpression="REST Config" domainClass="microserviceMetamodell::RestEndpoint" semanticCandidateExpression="var:self" groups="//@extensions.0/@categories.0/@groups.0"/>
      <groups name="REST Config Group" label="REST Config Group" labelExpression="Group" domainClass="microserviceMetamodell::RestEndpoint" semanticCandidateExpression="var:self">
        <controls xsi:type="properties:RadioDescription" name="HTTP Method Radio Button" label="HTTP Method Radio Button" labelExpression="HTTP Method" valueExpression="feature:httpMethod" candidatesExpression="aql:Sequence{microserviceMetamodell::HttpMethod::GET, microserviceMetamodell::HttpMethod::POST, microserviceMetamodell::HttpMethod::DELETE}" candidateDisplayExpression="aql:candidate.toString()" numberOfColumns="1">
          <initialOperation>
            <firstModelOperations xsi:type="tool_1:SetValue" featureName="httpMethod" valueExpression="var:newValue"/>
          </initialOperation>
        </controls>
        <controls xsi:type="properties:TextDescription" name="URI" label="URI Textfield" labelExpression="URI:" valueExpression="aql:self.path">
          <initialOperation>
            <firstModelOperations xsi:type="tool_1:SetValue" featureName="path" valueExpression="var:newValue"/>
          </initialOperation>
        </controls>
      </groups>
    </categories>
  </extensions>
</description:Group>
