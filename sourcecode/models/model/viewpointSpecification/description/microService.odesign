  <extensions xsi:type="properties:ViewExtensionDescription" name="CustomProperties">
    <categories name="Default Category">
      <pages name="REST Config Page" label="REST Config Page" labelExpression="REST Config" domainClass="microserviceMetamodell::RestEndpoint" semanticCandidateExpression="var:self" groups="//@extensions.0/@categories.0/@groups.0"/>
      <groups name="REST Config Group" label="REST Config Group" labelExpression="Group" domainClass="microserviceMetamodell::RestEndpoint" semanticCandidateExpression="var:self">
        <controls xsi:type="properties:RadioDescription" name="HTTP Method Radio Button" label="HTTP Method Radio Button" labelExpression="HTTP Method" valueExpression="feature:httpMethod" candidatesExpression="aql:Sequence{microserviceMetamodell::HttpMethod::GET, microserviceMetamodell::HttpMethod::POST, microserviceMetamodell::HttpMethod::DELETE}" candidateDisplayExpression="aql:candidate.toString()" numberOfColumns="1">
          <initialOperation>
            <firstModelOperations xsi:type="tool_1:SetValue" featureName="httpMethod" valueExpression="var:newValue"/>
          </initialOperation>
        </controls>
        <controls xsi:type="properties:TextDescription" name="URI" label="URI Textfield" labelExpression="URI:" valueExpression="aql:self.path">
          <initialOperation>
            <firstModelOperations xsi:type="tool_1:SetValue" featureName="path" valueExpression="var:newValue"/>
          </initialOperation>
        </controls>
      </groups>
    </categories>
  </extensions>
</description:Group>
