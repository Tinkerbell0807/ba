              <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
              <backgroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='light_purple']"/>
              <foregroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='purple']"/>
            </style>
          </subContainerMappings>
          <style xsi:type="style:FlatContainerStyleDescription" borderSizeComputationExpression="1" labelSize="12" labelExpression="feature:domainName">
            <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
            <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
            <backgroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='white']"/>
            <foregroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='light_gray']"/>
          </style>
        </containerMappings>
        <toolSections name="Objekte">
          <ownedTools xsi:type="tool:ContainerCreationDescription" name="WebserviceCreation" label="Webservice" containerMappings="//@ownedViewpoints[name='ModelViewpoint']/@ownedRepresentations[name='DomainModelDescription']/@defaultLayer/@containerMappings[name='domainWebserviceContainer']">
            <variable name="container"/>
            <viewVariable name="containerView"/>
            <initialOperation>
              <firstModelOperations xsi:type="tool_1:ChangeContext" browseExpression="var:container">
                <subModelOperations xsi:type="tool_1:CreateInstance" typeName="microserviceMetamodell::DomainWebservice" referenceName="webservices">
                  <subModelOperations xsi:type="tool_1:SetValue" featureName="domainName" valueExpression="DefaultDomain"/>
                  <subModelOperations xsi:type="tool_1:SetValue" featureName="hostUrl" valueExpression="DefaultHostUrl"/>
                </subModelOperations>
              </firstModelOperations>
            </initialOperation>
          </ownedTools>
          <ownedTools xsi:type="tool:ContainerCreationDescription" name="DomainObject" label="DomainObject" containerMappings="//@ownedViewpoints[name='ModelViewpoint']/@ownedRepresentations[name='DomainModelDescription']/@defaultLayer/@containerMappings[name='domainWebserviceContainer']/@subContainerMappings[name='domainObjectContainer']">
            <variable name="container"/>
            <viewVariable name="containerView"/>
            <initialOperation>
              <firstModelOperations xsi:type="tool_1:ChangeContext" browseExpression="var:container">
                <subModelOperations xsi:type="tool_1:CreateInstance" typeName="microserviceMetamodell::DomainObject" referenceName="domainObjects">
                  <subModelOperations xsi:type="tool_1:SetValue" featureName="objectName" valueExpression="DefaultDomainName"/>
                </subModelOperations>
              </firstModelOperations>
            </initialOperation>
          </ownedTools>
          <ownedTools xsi:type="tool:NodeCreationDescription" name="Controller" label="Controller" precondition="aql:self.oclIsTypeOf(microserviceMetamodell::DomainObject)" nodeMappings="//@ownedViewpoints[name='ModelViewpoint']/@ownedRepresentations[name='DomainModelDescription']/@defaultLayer/@containerMappings[name='domainWebserviceContainer']/@subContainerMappings[name='domainObjectContainer']/@subNodeMappings[name='domainObjectControllerNode']" extraMappings="//@ownedViewpoints[name='ModelViewpoint']/@ownedRepresentations[name='DomainModelDescription']/@defaultLayer/@containerMappings[name='domainWebserviceContainer']/@subContainerMappings[name='domainObjectContainer']">
            <variable name="container"/>
            <viewVariable name="containerView"/>
            <initialOperation>
              <firstModelOperations xsi:type="tool_1:ChangeContext" browseExpression="aql:self.eContainer().oclAsType(microserviceMetamodell::DomainWebservice)">
                <subModelOperations xsi:type="tool_1:CreateInstance" typeName="microserviceMetamodell::DomainObjectController" referenceName="domainObjectControllers">
                  <subModelOperations xsi:type="tool_1:ChangeContext" browseExpression="var:container">
                    <subModelOperations xsi:type="tool_1:SetValue" featureName="domainObjectController" valueExpression="var:instance"/>
                  </subModelOperations>
                  <subModelOperations xsi:type="tool_1:SetValue" featureName="objectName" valueExpression="DefaultDomainController"/>
                </subModelOperations>
              </firstModelOperations>
            </initialOperation>
          </ownedTools>
          <ownedTools xsi:type="tool:NodeCreationDescription" name="RestEndpoint" label="RestEndpoint" precondition="aql:self.oclIsTypeOf(microserviceMetamodell::DomainObjectController)" nodeMappings="//@ownedViewpoints[name='ModelViewpoint']/@ownedRepresentations[name='DomainModelDescription']/@defaultLayer/@containerMappings[name='domainWebserviceContainer']/@subContainerMappings[name='domainObjectContainer']/@subNodeMappings[name='domainObjectControllerNode']/@borderedNodeMappings[name='restEndpointNode']">
            <variable name="container"/>
            <viewVariable name="containerView"/>
            <initialOperation>
              <firstModelOperations xsi:type="tool_1:ChangeContext" browseExpression="var:container">
                <subModelOperations xsi:type="tool_1:CreateInstance" typeName="microserviceMetamodell::RestEndpoint" referenceName="restEndpoints">
                  <subModelOperations xsi:type="tool_1:SetValue" featureName="path" valueExpression="/defaultApiRoute"/>
                </subModelOperations>
              </firstModelOperations>
            </initialOperation>
          </ownedTools>
          <ownedTools xsi:type="tool:NodeCreationDescription" name="Service" label="Service" precondition="aql:self.oclIsTypeOf(microserviceMetamodell::DomainObject)" nodeMappings="//@ownedViewpoints[name='ModelViewpoint']/@ownedRepresentations[name='DomainModelDescription']/@defaultLayer/@containerMappings[name='domainWebserviceContainer']/@subContainerMappings[name='domainObjectContainer']/@subNodeMappings[name='domainServiceNode']">
            <variable name="container"/>
            <viewVariable name="containerView"/>
            <initialOperation>
              <firstModelOperations xsi:type="tool_1:ChangeContext" browseExpression="aql:self.eContainer().oclAsType(microserviceMetamodell::DomainWebservice)">
                <subModelOperations xsi:type="tool_1:CreateInstance" typeName="microserviceMetamodell::DomainObjectService" referenceName="domainObjectServices">
                  <subModelOperations xsi:type="tool_1:ChangeContext" browseExpression="var:container">
                    <subModelOperations xsi:type="tool_1:SetValue" featureName="domainObjectService" valueExpression="var:instance"/>
                  </subModelOperations>
                  <subModelOperations xsi:type="tool_1:SetValue" featureName="objectName" valueExpression="DefaultDomainService"/>
                </subModelOperations>
              </firstModelOperations>
            </initialOperation>
          </ownedTools>
          <ownedTools xsi:type="tool:NodeCreationDescription" name="Repository" label="Repository" nodeMappings="//@ownedViewpoints[name='ModelViewpoint']/@ownedRepresentations[name='DomainModelDescription']/@defaultLayer/@containerMappings[name='domainWebserviceContainer']/@subContainerMappings[name='domainObjectContainer']/@subNodeMappings[name='domainRepositoryNode']">
