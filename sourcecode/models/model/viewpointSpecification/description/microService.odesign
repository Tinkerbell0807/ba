                  <subModelOperations xsi:type="tool_1:ChangeContext" browseExpression="var:container">
                    <subModelOperations xsi:type="tool_1:SetValue" featureName="domainObjectRepository" valueExpression="var:instance"/>
                  </subModelOperations>
                  <subModelOperations xsi:type="tool_1:SetValue" featureName="objectName" valueExpression="DefaultDomainRepository"/>
                </subModelOperations>
              </firstModelOperations>
            </initialOperation>
