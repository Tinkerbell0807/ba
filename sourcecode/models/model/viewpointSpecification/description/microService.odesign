      <defaultLayer name="ServiceInfrastructureLayer">
        <edgeMappings name="correspondingDeployement" sourceMapping="//@ownedViewpoints[name='ModelViewpoint']/@ownedRepresentations[name='MicroserviceInfrastructureDescription']/@defaultLayer/@containerMappings[name='microservice']" targetMapping="//@ownedViewpoints[name='ModelViewpoint']/@ownedRepresentations[name='MicroserviceInfrastructureDescription']/@defaultLayer/@containerMappings[name='deployementAbstraction']" targetFinderExpression="aql:self.deployementAbstraction">
