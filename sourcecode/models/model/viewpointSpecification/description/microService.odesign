<?xml version="1.0" encoding="UTF-8"?>
<description:Group xmi:version="2.0" xmlns:xmi="http://www.omg.org/XMI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:description="http://www.eclipse.org/sirius/description/1.1.0" xmlns:description_1="http://www.eclipse.org/sirius/diagram/description/1.1.0" xmlns:properties="http://www.eclipse.org/sirius/properties/1.0.0" xmlns:style="http://www.eclipse.org/sirius/diagram/description/style/1.1.0" xmlns:tool="http://www.eclipse.org/sirius/diagram/description/tool/1.1.0" xmlns:tool_1="http://www.eclipse.org/sirius/description/tool/1.1.0" name="microService" version="12.0.0.2017041100">
  <ownedViewpoints name="ModelViewpoint" modelFileExtension="*.microservicemetamodell">
    <ownedRepresentations xsi:type="description_1:DiagramDescription" name="ContextRelationshipDescription" domainClass="microserviceMetamodell::DomainModelLayer" enablePopupBars="true">
      <metamodel href="http://microservice.com/microserviceMetamodell#/"/>
      <defaultLayer name="contextElements">
        <edgeMappings name="sharedKernelEdge" sourceMapping="//@ownedViewpoints[name='ModelViewpoint']/@ownedRepresentations[name='ContextRelationshipDescription']/@defaultLayer/@containerMappings[name='boundedContext']" targetMapping="//@ownedViewpoints[name='ModelViewpoint']/@ownedRepresentations[name='ContextRelationshipDescription']/@defaultLayer/@containerMappings[name='sharedKernel']" targetFinderExpression="aql:self" sourceFinderExpression="aql:self.relatedContexts" domainClass="microserviceMetamodell::SharedKernel" useDomainElement="true">
          <style sourceArrow="FillDiamond" targetArrow="NoDecoration" sizeComputationExpression="2">
            <strokeColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
            <centerLabelStyleDescription labelSize="12">
              <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
            </centerLabelStyleDescription>
          </style>
        </edgeMappings>
        <containerMappings name="boundedContext" domainClass="microserviceMetamodell::BoundedContext">
          <borderedNodeMappings name="domainModel" semanticCandidatesExpression="aql:self.domainModel" domainClass="microserviceMetamodell::DomainModel">
            <style xsi:type="style:SquareDescription" labelSize="12" labelExpression="Domain Model" labelPosition="node" resizeKind="NSEW">
              <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
              <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
              <color xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='light_orange']"/>
            </style>
          </borderedNodeMappings>
          <borderedNodeMappings name="microservice" semanticCandidatesExpression="aql:self.correspodingMicroservice" domainClass="microserviceMetamodell::Microservice">
            <style xsi:type="style:SquareDescription" labelSize="12" labelExpression="aql:self.serviceName" labelPosition="node" resizeKind="NSEW">
              <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
              <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
              <color xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='light_gray']"/>
            </style>
          </borderedNodeMappings>
          <subContainerMappings name="module" semanticCandidatesExpression="aql:self.domainModel.modules" domainClass="Module">
            <subContainerMappings name="submodule" semanticCandidatesExpression="aql:self.submodules" domainClass="microserviceMetamodell::Module" reusedContainerMappings="//@ownedViewpoints[name='ModelViewpoint']/@ownedRepresentations[name='ContextRelationshipDescription']/@defaultLayer/@containerMappings[name='boundedContext']/@subContainerMappings[name='module']/@subContainerMappings[name='submodule']">
              <style xsi:type="style:FlatContainerStyleDescription" borderSizeComputationExpression="1" labelSize="14" labelExpression="aql:self.moduleName" labelAlignment="LEFT">
                <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
                <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
                <backgroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='white']"/>
                <foregroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='white']"/>
              </style>
            </subContainerMappings>
            <style xsi:type="style:FlatContainerStyleDescription" borderSizeComputationExpression="1" labelSize="14" labelExpression="aql:self.moduleName" labelAlignment="LEFT">
              <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
              <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
              <backgroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='white']"/>
              <foregroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='white']"/>
            </style>
          </subContainerMappings>
          <style xsi:type="style:FlatContainerStyleDescription" borderSizeComputationExpression="1" labelSize="14" labelExpression="aql:self.contextName">
            <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
            <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
            <backgroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='light_yellow']"/>
            <foregroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='light_yellow']"/>
          </style>
        </containerMappings>
        <containerMappings name="sharedKernel" semanticCandidatesExpression="aql:self.boundedContextRelationships" domainClass="SharedKernel">
          <subContainerMappings name="module" semanticCandidatesExpression="aql:self.sharedModules" domainClass="Module">
            <subContainerMappings name="submodule" semanticCandidatesExpression="aql:self.submodules" domainClass="microserviceMetamodell::Module" reusedContainerMappings="//@ownedViewpoints[name='ModelViewpoint']/@ownedRepresentations[name='ContextRelationshipDescription']/@defaultLayer/@containerMappings[name='sharedKernel']/@subContainerMappings[name='module']/@subContainerMappings[name='submodule']">
              <style xsi:type="style:FlatContainerStyleDescription" borderSizeComputationExpression="1" labelSize="14" labelExpression="aql:self.moduleName" labelAlignment="LEFT">
                <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
                <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
                <backgroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='white']"/>
                <foregroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='white']"/>
              </style>
            </subContainerMappings>
            <style xsi:type="style:FlatContainerStyleDescription" borderSizeComputationExpression="1" labelSize="14" labelExpression="aql:self.moduleName" labelAlignment="LEFT">
              <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
              <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
              <backgroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='white']"/>
              <foregroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='white']"/>
            </style>
          </subContainerMappings>
          <style xsi:type="style:FlatContainerStyleDescription" borderSizeComputationExpression="1" labelSize="14" labelExpression="Shared Context" labelAlignment="LEFT">
            <borderColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
            <labelColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='black']"/>
            <backgroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='light_red']"/>
            <foregroundColor xsi:type="description:SystemColor" href="environment:/viewpoint#//@systemColors/@entries[name='light_red']"/>
          </style>
        </containerMappings>
      </defaultLayer>
    </ownedRepresentations>
    <ownedRepresentations xsi:type="description_1:DiagramDescription" name="DomainModelDescription" domainClass="microserviceMetamodell::DomainModel" enablePopupBars="true">
      <metamodel href="http://microservice.com/microserviceMetamodell#/"/>
      <defaultLayer name="outdatedLayer">
        <edgeMappings name="serviceMaintainedBy" label="serviceMaintainedBy" sourceMapping="//@ownedViewpoints[name='ModelViewpoint']/@ownedRepresentations[name='DomainModelDescription']/@defaultLayer/@containerMappings[name='domainWebserviceContainer']/@subContainerMappings[name='domainObjectContainer']/@subNodeMappings[name='domainObjectControllerNode']" targetMapping="//@ownedViewpoints[name='ModelViewpoint']/@ownedRepresentations[name='DomainModelDescription']/@defaultLayer/@containerMappings[name='domainWebserviceContainer']/@subContainerMappings[name='domainObjectContainer']/@subNodeMappings[name='domainServiceNode']" targetFinderExpression="aql:self.domainObjectServices">
